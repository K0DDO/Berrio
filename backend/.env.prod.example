APP_NAME=Berrio
APP_ENV=production
DEBUG=false
API_PREFIX=/api/v1
LOG_LEVEL=INFO
REQUIRE_SECURE_SECRETS=true
API_RATE_LIMIT_PER_MINUTE=180

# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
JWT_SECRET=
EMAIL_HASH_PEPPER=
FIELD_ENCRYPTION_KEY=

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=180
ENABLE_API_DOCS=false

POSTGRES_USER=berrio
POSTGRES_PASSWORD=
POSTGRES_DB=berrio

# Filled by compose for containers; keep for host-side backup scripts
DATABASE_URL=postgresql+asyncpg://berrio:CHANGE_ME@postgres:5432/berrio
DATABASE_URL_SYNC=postgresql://berrio:CHANGE_ME@postgres:5432/berrio

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Your app / web origins only — no wildcard
CORS_ORIGINS=["https://app.example.com"]

# Optional integrations
# KIMI_API_KEY=
# FNS_API_TOKEN=
# FNS_PROVIDER=auto
