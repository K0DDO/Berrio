APP_NAME=Berrio
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1

SECRET_KEY=change-me-in-production-use-long-random-string
FIELD_ENCRYPTION_KEY=
EMAIL_HASH_PEPPER=berrio-email-pepper-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

EMAIL_VERIFICATION_ENABLED=false
PASSWORD_RESET_ENABLED=false
EMAIL_VERIFICATION_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_HOURS=1

DATABASE_URL=postgresql+asyncpg://berrio:berrio@localhost:5432/berrio
DATABASE_URL_SYNC=postgresql://berrio:berrio@localhost:5432/berrio

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","*"]

# Optional — enables real Kimi/Moonshot instead of StubAiClient
# KIMI_API_KEY=
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# KIMI_MODEL=moonshot-v1-8k

# Optional — real FNS via proverkacheka.com (falls back to stub without token)
# FNS_PROVIDER=auto
# FNS_API_TOKEN=
# FNS_API_URL=https://proverkacheka.com/api/v1/check/get
