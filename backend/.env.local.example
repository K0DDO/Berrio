APP_NAME=Berrio
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1
LOG_LEVEL=INFO

# Required — never leave empty
SECRET_KEY=local-dev-secret-change-me-but-ok-for-beta
EMAIL_HASH_PEPPER=local-dev-email-pepper
# Optional for local; falls back to SECRET_KEY if empty
FIELD_ENCRYPTION_KEY=

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

EMAIL_VERIFICATION_ENABLED=false
PASSWORD_RESET_ENABLED=false

# Local Postgres / Redis (docker compose or native)
DATABASE_URL=postgresql+asyncpg://berrio:berrio@localhost:5432/berrio
DATABASE_URL_SYNC=postgresql://berrio:berrio@localhost:5432/berrio
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Allow Flutter on emulator + LAN devices during local beta
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","*"]

API_RATE_LIMIT_PER_MINUTE=300
REQUIRE_SECURE_SECRETS=false

# Seed demo user + receipts on API startup (development only)
SEED_DEMO_DATA=true

# Optional integrations
# KIMI_API_KEY=
# FNS_API_TOKEN=
# FNS_PROVIDER=auto
