# Copy to .env.production on the VPS (never commit real secrets).
#   cp .env.production.example .env.production
#
# Generate secrets:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"

APP_NAME=Berrio
APP_ENV=production
DEBUG=false
API_PREFIX=/api/v1
LOG_LEVEL=INFO
REQUIRE_SECURE_SECRETS=true
ENABLE_API_DOCS=true
API_RATE_LIMIT_PER_MINUTE=180
WEB_CONCURRENCY=2

# Bind on shared VPS: keep API on localhost; nginx (or SSH tunnel) reaches it.
# Use API_BIND=0.0.0.0 only for a short public smoke test.
API_BIND=127.0.0.1
# Host port mapped to container :8000 (change if something else already uses 8000)
API_HOST_PORT=8000

# --- Secrets (min 32 bytes each for JWT / signing) ---
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
JWT_SECRET=
EMAIL_HASH_PEPPER=
FIELD_ENCRYPTION_KEY=

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Postgres (compose injects DATABASE_* URLs for containers) ---
POSTGRES_USER=berrio
POSTGRES_PASSWORD=
POSTGRES_DB=berrio

DATABASE_URL=postgresql+asyncpg://berrio:CHANGE_ME@postgres:5432/berrio
DATABASE_URL_SYNC=postgresql://berrio:CHANGE_ME@postgres:5432/berrio

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Mobile / web origins — use http://SERVER_IP until you have a domain
CORS_ORIGINS=["http://SERVER_IP","http://SERVER_IP:8000"]

# --- Receipts: real line items (names, prices) from OFD ---
# Without FNS_API_TOKEN the API uses stub → needs_confirmation, no invented items.
# Get a token at https://proverkacheka.com (partner API), then set:
FNS_PROVIDER=auto
FNS_API_TOKEN=
# FNS_API_URL=https://proverkacheka.com/api/v1/check/get

# Optional AI
# KIMI_API_KEY=
