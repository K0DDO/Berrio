# Local network security — allow cleartext HTTP to LAN API during beta.
# Production builds should prefer HTTPS (dart-define API_BASE_URL=https://…).
<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
